# Supabase PostgreSQL
# Pooler connection (port 6543) — app runtime
DATABASE_URL="postgresql://user:password@host:6543/dbname?pgbouncer=true"
# Direct connection (port 5432) — Prisma migrations
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Auth.js
AUTH_SECRET="generate-with-npx-auth-secret"
AUTH_URL="http://localhost:3000"
