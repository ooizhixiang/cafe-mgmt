generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MANAGER
  STAFF
}

enum Period {
  OPENING
  MID_DAY
  CLOSING
}

model Cafe {
  id        String   @id @default(cuid())
  name      String   @default("My Cafe")

  // Checklist time boundaries (HH:mm format, null = use defaults)
  openingStart String?
  openingEnd   String?
  midDayStart  String?
  midDayEnd    String?
  closingStart String?
  closingEnd   String?

  // Template selection (null = not selected)
  templateSelected String?

  // Onboarding steps completed (Story 1.5)
  onboardingCompletedSteps String[] @default([])

  // Cafe-managed unit picker vocabulary (cafe-enabled-units feature).
  enabledUnits String[] @default(["kg", "g", "L", "mL", "each"])

  // Minimum margin floor (%). Action feed warns about recipes priced below it.
  minMarginPercent Int @default(20)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  invites            Invite[]
  errorLogs          ErrorLog[]
  ingredients        Ingredient[]
  checklistTemplates ChecklistTemplate[]
  suppliers          Supplier[]
  dailyChecklists    DailyChecklist[]
  inventoryCounts    InventoryCount[]
  feedAlerts         FeedAlert[]
  wastageEntries     WastageEntry[]
  compEntries        CompEntry[]
  compBudget         CompBudget?
  recipes            Recipe[]
  salesEntries       SalesEntry[]
  grabAndGoItems     GrabAndGoItem[]
  ingredientSuppliers IngredientSupplier[]
  ingredientPurchases IngredientPurchase[]
  lotConsumptions     LotConsumption[]
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  passwordHash        String
  name                String
  role                Role      @default(STAFF)
  cafeId              String
  isActive            Boolean   @default(true)
  mustChangePassword  Boolean   @default(false)
  firstLoginAt            DateTime?
  orientationDismissedAt  DateTime?
  lastSeenAt              DateTime?
  darkMode                Boolean   @default(false)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  cafe               Cafe               @relation(fields: [cafeId], references: [id])
  sessions           Session[]
  errorLogs          ErrorLog[]
  completedItems     DailyChecklistItem[] @relation("CompletedBy")
  confirmedCounts    InventoryCount[]     @relation("ConfirmedCounts")
  wastageCreated     WastageEntry[]       @relation("WastageCreator")
  wastageVoided      WastageEntry[]       @relation("WastageVoider")
  compCreated        CompEntry[]          @relation("CompCreator")
  compVoided         CompEntry[]          @relation("CompVoider")
  supplierCalls      SupplierCallLog[]    @relation("SupplierCaller")
  pushSubscriptions  PushSubscription[]
  salesEntries       SalesEntry[]         @relation("SalesCreator")
  salesVoided        SalesEntry[]         @relation("SalesVoider")
  ingredientPurchases IngredientPurchase[] @relation("PurchaseCreator")

  @@index([cafeId])
  @@index([email])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

model Invite {
  id        String    @id @default(cuid())
  code      String    @unique
  cafeId    String
  role      Role      @default(STAFF)
  createdAt DateTime  @default(now())
  usedAt    DateTime?
  expiresAt DateTime
  revokedAt DateTime?

  cafe Cafe @relation(fields: [cafeId], references: [id])

  @@index([code])
  @@index([cafeId])
}

model ErrorLog {
  id        String   @id @default(cuid())
  context   String
  message   String
  stack     String?
  userId    String?
  cafeId    String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
  cafe Cafe? @relation(fields: [cafeId], references: [id])

  @@index([cafeId])
  @@index([createdAt])
}

model Ingredient {
  id                 String   @id @default(cuid())
  name               String
  unit               String
  // Optional display-time conversion target (within-dimension). Inventory
  // surfaces convert stored quantities to this unit at render. Null = no
  // conversion (parity with pre-feature behavior).
  displayUnit        String?
  displayOrder       Int
  cafeId             String
  costPerUnitInCents Decimal? @db.Decimal(12, 4)
  snapIncrement      Int?
  containerProfile   String?
  category           String?
  isPinned           Boolean  @default(false)
  manualCostOverride Boolean  @default(true)
  lowStockThreshold  Int?
  unitsPerContainer  Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  cafe               Cafe               @relation(fields: [cafeId], references: [id])
  ingredientSuppliers IngredientSupplier[]
  inventoryCounts    InventoryCount[]
  wastageEntries     WastageEntry[]
  compEntries        CompEntry[]
  feedAlerts         FeedAlert[]
  recipeIngredients      RecipeIngredient[]
  variationIngredients   VariationIngredient[]

  @@index([cafeId])
}

model ChecklistTemplate {
  id        String   @id @default(cuid())
  name      String
  period    Period
  cafeId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cafe             Cafe                    @relation(fields: [cafeId], references: [id])
  items            ChecklistTemplateItem[]
  dailyChecklists  DailyChecklist[]

  @@index([cafeId])
}

model ChecklistTemplateItem {
  id                  String  @id @default(cuid())
  text                String
  displayOrder        Int
  notes               String?
  role                Role?
  linkRoute           String?
  checklistTemplateId String

  template ChecklistTemplate @relation(fields: [checklistTemplateId], references: [id], onDelete: Cascade)

  @@index([checklistTemplateId])
}

model Supplier {
  id            String    @id @default(cuid())
  name          String
  phone         String?
  notes         String?
  displayOrder  Int
  cafeId        String
  lastOrderDate DateTime?
  reminderDays  Int       @default(7)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  cafe                Cafe                 @relation(fields: [cafeId], references: [id])
  callLogs            SupplierCallLog[]
  ingredientSuppliers IngredientSupplier[]

  @@index([cafeId])
}

model DailyChecklist {
  id                    String   @id @default(cuid())
  cafeId                String
  date                  DateTime @db.Date
  period                Period
  checklistTemplateId   String
  createdAt             DateTime @default(now())

  cafe     Cafe                    @relation(fields: [cafeId], references: [id])
  template ChecklistTemplate       @relation(fields: [checklistTemplateId], references: [id])
  items    DailyChecklistItem[]

  @@unique([cafeId, date, period])
  @@index([cafeId, date])
}

model DailyChecklistItem {
  id                      String    @id @default(cuid())
  dailyChecklistId        String
  checklistTemplateItemId String?
  text                    String
  displayOrder            Int
  notes                   String?
  role                    Role?
  linkRoute               String?
  completedAt             DateTime?
  completedById           String?

  dailyChecklist DailyChecklist @relation(fields: [dailyChecklistId], references: [id], onDelete: Cascade)
  completedBy    User?          @relation("CompletedBy", fields: [completedById], references: [id])

  @@index([dailyChecklistId])
}

// ─── Epic 3: Inventory & Wastage ────────────────────────────

enum AlertType {
  LOW_STOCK
  COMP_WARNING
}

enum AlertSeverity {
  WARNING
  URGENT
}

enum WastageReason {
  SPILLED
  EXPIRED
  INCORRECT
}

enum ConsumptionKind {
  LOT
  OVER_DEDUCTION
}

model InventoryCount {
  id                String   @id @default(cuid())
  ingredientId      String
  cafeId            String
  countDate         DateTime @db.Date
  quantity          Int
  dollarValueInCents Int?
  confirmedById     String
  confirmedAt       DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  ingredient  Ingredient @relation(fields: [ingredientId], references: [id])
  cafe        Cafe       @relation(fields: [cafeId], references: [id])
  confirmedBy User       @relation("ConfirmedCounts", fields: [confirmedById], references: [id])

  @@unique([ingredientId, countDate])
  @@index([ingredientId, countDate])
  @@index([cafeId])
}

model FeedAlert {
  id           String        @id @default(cuid())
  cafeId       String
  type         AlertType
  ingredientId String?
  title        String
  message      String
  severity     AlertSeverity
  resolvedAt   DateTime?
  createdAt    DateTime      @default(now())

  cafe       Cafe        @relation(fields: [cafeId], references: [id])
  ingredient Ingredient? @relation(fields: [ingredientId], references: [id])

  @@index([cafeId, resolvedAt])
}

model WastageEntry {
  id                 String        @id @default(cuid())
  cafeId             String
  ingredientId       String
  quantity           Int
  reason             WastageReason
  dollarValueInCents Int
  createdById        String
  deletedAt          DateTime?
  voidedAt           DateTime?
  voidedById         String?
  voidReason         String?
  originalQuantity   Int?
  correctedQuantity  Int?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  cafe       Cafe       @relation(fields: [cafeId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  createdBy  User       @relation("WastageCreator", fields: [createdById], references: [id])
  voidedBy   User?      @relation("WastageVoider", fields: [voidedById], references: [id])

  @@index([cafeId, createdAt])
}

model CompEntry {
  id                 String    @id @default(cuid())
  cafeId             String
  ingredientId       String
  quantity           Int
  reason             String
  dollarValueInCents Int
  createdById        String
  flaggedForReview   Boolean   @default(false)
  deletedAt          DateTime?
  voidedAt           DateTime?
  voidedById         String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  cafe       Cafe       @relation(fields: [cafeId], references: [id])
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])
  createdBy  User       @relation("CompCreator", fields: [createdById], references: [id])
  voidedBy   User?      @relation("CompVoider", fields: [voidedById], references: [id])

  @@index([cafeId, createdAt])
}

model CompBudget {
  id            String   @id @default(cuid())
  cafeId        String   @unique
  amountInCents Int
  resetDay      Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cafe Cafe @relation(fields: [cafeId], references: [id])
}

// ─── Epic 4: Suppliers & Recipes ────────────────────────────

enum CallOutcome {
  ORDERED
  NO_ANSWER
  CALL_BACK
}

model SupplierCallLog {
  id         String      @id @default(cuid())
  supplierId String
  outcome    CallOutcome
  calledById String
  createdAt  DateTime    @default(now())

  supplier  Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  calledBy  User                 @relation("SupplierCaller", fields: [calledById], references: [id])
  purchases IngredientPurchase[]

  @@index([supplierId, createdAt])
}

model IngredientSupplier {
  id           String   @id @default(cuid())
  ingredientId String
  supplierId   String
  cafeId       String
  priceInCents Decimal  @db.Decimal(12, 4)
  unit         String   @default("kg")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  ingredient Ingredient           @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  supplier   Supplier             @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  cafe       Cafe                 @relation(fields: [cafeId], references: [id])
  purchases  IngredientPurchase[]

  @@unique([ingredientId, supplierId, cafeId])
  @@index([cafeId])
}

model IngredientPurchase {
  id                   String   @id @default(cuid())
  ingredientSupplierId String
  cafeId               String
  quantity             Int
  remainingQuantity    Int      @default(0)
  unit                 String
  totalPriceInCents    Decimal  @db.Decimal(12, 4)
  supplierCallLogId    String?
  invoiceImageUrl      String?
  createdById          String
  createdAt            DateTime @default(now())

  ingredientSupplier IngredientSupplier @relation(fields: [ingredientSupplierId], references: [id], onDelete: Cascade)
  supplierCallLog    SupplierCallLog?   @relation(fields: [supplierCallLogId], references: [id], onDelete: SetNull)
  cafe               Cafe               @relation(fields: [cafeId], references: [id])
  createdBy          User               @relation("PurchaseCreator", fields: [createdById], references: [id])
  lotConsumptions    LotConsumption[]

  @@index([cafeId, createdAt])
  @@index([ingredientSupplierId])
}

model LotConsumption {
  id                   String          @id @default(cuid())
  cafeId               String
  sourceType           String
  sourceId             String
  ingredientPurchaseId String?
  quantityConsumed     Int
  perUnitInCents       Decimal         @db.Decimal(12, 4)
  consumptionKind      ConsumptionKind @default(LOT)
  createdAt            DateTime        @default(now())

  cafe               Cafe                @relation(fields: [cafeId], references: [id])
  ingredientPurchase IngredientPurchase? @relation(fields: [ingredientPurchaseId], references: [id], onDelete: SetNull)

  @@index([sourceType, sourceId])
  @@index([cafeId, createdAt])
  @@index([ingredientPurchaseId])
}

model Recipe {
  id          String   @id @default(cuid())
  name        String
  description String?
  servingSize String?
  imageUrl       String?
  notes          String?
  category             String?
  sellingPriceInCents  Int?
  discontinued         Boolean  @default(false)
  // Sub-recipe yield: when set, this recipe can be referenced by other
  // recipes as a composite ingredient. Both fields cleared together (or
  // both set together) — partial null rejected at the action layer.
  yieldQuantity        Int?
  yieldUnit            String?
  cafeId         String
  createdAt      DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cafe        Cafe               @relation(fields: [cafeId], references: [id])
  ingredients RecipeIngredient[]
  steps       RecipeStep[]
  variations  RecipeVariation[]
  // Inverse: rows that USE this recipe as a sub-recipe (so deletion can
  // surface "still in use" if we ever want to defend against it).
  parentIngredients         RecipeIngredient[]    @relation("SubRecipeOnRecipeIngredient")
  parentVariationIngredients VariationIngredient[] @relation("SubRecipeOnVariationIngredient")

  @@index([cafeId])
}

model RecipeIngredient {
  id                      String   @id @default(cuid())
  recipeId                String
  // Polymorphic: exactly one of `ingredientId` or `subRecipeId` is non-null
  // (XOR enforced at the action layer — Prisma can't express it cleanly).
  // `ingredientId` non-null is the legacy "raw ingredient" row; `subRecipeId`
  // non-null is the new "composite" row referencing another Recipe.
  ingredientId            String?
  subRecipeId             String?
  quantityPerServing      Int
  subtotalOverrideInCents Decimal? @db.Decimal(12, 4)
  createdAt               DateTime @default(now())

  recipe     Recipe      @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient? @relation(fields: [ingredientId], references: [id])
  // Restrict deletion of a sub-recipe that's still referenced. Without this
  // (default SET NULL), deleting the sub silently leaves orphan rows with
  // BOTH ingredientId AND subRecipeId null — which the engine treats as a
  // skip-and-continue, producing silent under-deduction at sale time.
  subRecipe  Recipe?     @relation("SubRecipeOnRecipeIngredient", fields: [subRecipeId], references: [id], onDelete: Restrict)

  @@index([recipeId])
}

model RecipeStep {
  id          String   @id @default(cuid())
  recipeId    String
  stepNumber  Int
  instruction String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}

model RecipeVariation {
  id                    String   @id @default(cuid())
  recipeId              String
  name                  String
  sellingPriceInCents   Int?
  createdAt             DateTime @default(now())

  recipe      Recipe                 @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredients VariationIngredient[]
  steps       VariationStep[]

  @@index([recipeId])
}

model VariationStep {
  id          String   @id @default(cuid())
  variationId String
  stepNumber  Int
  instruction String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variation RecipeVariation @relation(fields: [variationId], references: [id], onDelete: Cascade)

  @@index([variationId])
}

model VariationIngredient {
  id                      String   @id @default(cuid())
  variationId             String
  // Polymorphic — see RecipeIngredient. XOR enforced at the action layer.
  ingredientId            String?
  subRecipeId             String?
  quantityPerServing      Int
  subtotalOverrideInCents Int?
  createdAt               DateTime @default(now())

  variation  RecipeVariation @relation(fields: [variationId], references: [id], onDelete: Cascade)
  ingredient Ingredient?     @relation(fields: [ingredientId], references: [id])
  subRecipe  Recipe?         @relation("SubRecipeOnVariationIngredient", fields: [subRecipeId], references: [id], onDelete: Restrict)

  @@index([variationId])
}

// ─── Grab & Go Items ────────────────────────────────────────

model GrabAndGoItem {
  id            String   @id @default(cuid())
  name          String
  imageUrl      String?
  priceInCents  Int      @default(0)
  stockCount    Int      @default(0)
  cafeId        String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  cafe Cafe @relation(fields: [cafeId], references: [id])

  @@index([cafeId])
}

// ─── Sales Tracking ─────────────────────────────────────────

model SalesEntry {
  id              String    @id @default(cuid())
  cafeId          String
  recipeId        String
  recipeName      String
  qtySold         Int
  revenueInCents  Int       @default(0)
  costInCents     Int       @default(0)
  saleDate        DateTime  @db.Date
  createdById     String
  submissionId    String?
  voidedAt        DateTime?
  voidedById      String?
  voidReason      String?
  createdAt       DateTime  @default(now())

  cafe      Cafe   @relation(fields: [cafeId], references: [id])
  createdBy User   @relation("SalesCreator", fields: [createdById], references: [id])
  voidedBy  User?  @relation("SalesVoider", fields: [voidedById], references: [id])

  @@index([cafeId, saleDate])
  @@index([recipeId, saleDate])
  @@index([cafeId, saleDate, submissionId])
}

// ─── Epic 5: Phase 2 Features ───────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
